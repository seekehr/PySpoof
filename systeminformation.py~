    def _processor_id(self):
        try:
            pythoncom.CoInitializeEx(pythoncom.COINIT_APARTMENTTHREADED)
            local_wmi = wmi.WMI()
            for processor in local_wmi.Win32_Processor():
                if processor.ProcessorId:
                    pythoncom.CoUninitialize()
