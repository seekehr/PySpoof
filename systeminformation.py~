            return None
        except Exception as e:
            print(f"{ERROR} {{Processor ID}}: {e}")
            return None

    def _disk_model(self):  # Function to fetch disk model
        try:
            result = subprocess.run("wmic diskdrive get model", capture_output=True, text=True, shell=True)
            if result.returncode == 0:
                model = result.stdout.splitlines()[1].strip()  # Extracting the model from the output
                return model
            return None
        except Exception as e:
            print(f"{ERROR} {{Disk Model}}: {e}")
            return None
