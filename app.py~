config = Config()
output = False
def handle_args():
    parser = argparse.ArgumentParser(description="Process some flags.")
    parser.add_argument('--o', dest="output", type=str, help="Specify output file path")
    args = parser.parse_args()
    if args.output:
        print(f"Output file: {args.output}")
    return args

def saveOutput(sys_info: SystemInformation, output_file=None):
    if output_file:
        _parse_output(output_file, sys_info)
    elif config.get("output"):
        outputFile = config.get("output")
        if isinstance(outputFile, str) and outputFile.endswith(".txt"):
            _parse_output(outputFile, sys_info)

def _parse_output(output_file, info):
    str = "Time: " +  datetime.now().strftime("%Y-%m-%d %H:%M:%S") + "\n\n"
    str += info.print()
    plain_text_output = _remove_ansi_escape_sequences(str)
    with open("./logs/" + output_file, "w") as f:
        f.write(plain_text_output)
    print(f"Output file: {output_file}")

def _remove_ansi_escape_sequences(text):
    # Regular expression to remove ANSI escape sequences (color codes)
    ansi_escape = re.compile(r'\x1b\[[0-9;]*m')
    return ansi_escape.sub('', text)

async def main():
    try:
        args = handle_args()
        sys_info = SystemInformation()
        print("Starting to load system information asynchronously...\n")
        await sys_info.load_system_info_async()
        sys_info.print()
        print("\nFinished loading. Time:", time.time() - start_time)
        saveOutput(sys_info, args.output)
    except Exception as e:
        print(f"{ERROR}: {e}")
        exit(1)

if __name__ == "__main__":
    # On Windows, ProactorEventLoop is the default for asyncio,
    # which works well with the ThreadPoolExecutor used here.
    # For other platforms, the default event loop should also be fine.
    asyncio.run(main())
